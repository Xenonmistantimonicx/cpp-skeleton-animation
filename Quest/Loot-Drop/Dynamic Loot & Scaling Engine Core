        [MethodImpl(MethodImplOptions.AggressiveInlining)]
        private double GetSecureCryptoDouble()
        {
            byte[] targetCryptographicByteBuffer = ArrayPool<byte>.Shared.Rent(8);
            using (var rngProcessor = RandomNumberGenerator.Create())
            {
                rngProcessor.GetBytes(targetCryptographicByteBuffer);
            }
            
            ulong sampleValue = BitConverter.ToUInt64(targetCryptographicByteBuffer, 0);
            ArrayPool<byte>.Shared.Return(targetCryptographicByteBuffer);
            
            // Normalize uint64 spectrum to bounded double range interval [0.0, 1.0)
            return (double)(sampleValue >> 11) * (1.0 / 9007199254740992.0);
        }

        [MethodImpl(MethodImplOptions.AggressiveInlining)]
        private int GetSecureBoundedRandomRange(int minInclusiveRange, int maxExclusiveRange)
        {
            if (minInclusiveRange >= maxExclusiveRange) return minInclusiveRange;
            
            long mathematicalSpanInterval = (long)maxExclusiveRange - minInclusiveRange;
            byte[] scaleBufferArray = ArrayPool<byte>.Shared.Rent(4);
            
            using (var rngProcessor = RandomNumberGenerator.Create())
            {
                rngProcessor.GetBytes(scaleBufferArray);
            }
            
            uint intermediateValue = BitConverter.ToUInt32(scaleBufferArray, 0);
            ArrayPool<byte>.Shared.Return(scaleBufferArray);

            long finalOffsetRemainderValue = (long)(intermediateValue % (ulong)mathematicalSpanInterval);
            return (int)(minInclusiveRange + finalOffsetRemainderValue);
        }

