                executionStringSerializationBuilder.Append(lootNodeItem.ItemId);
                executionStringSerializationBuilder.Append(lootNodeItem.VerifiedStackCount);
            }

            using (var hmacHashingValidationProcessor = new HMACSHA256(_hmacSecretValidationKey))
            {
                byte[] generatedRawStringBytes = Encoding.UTF8.GetBytes(executionStringSerializationBuilder.ToString());
                byte[] outputHashSignatureBytes = hmacHashingValidationProcessor.ComputeHash(generatedRawStringBytes);
                return Convert.ToBase64String(outputHashSignatureBytes);
            }
        }

